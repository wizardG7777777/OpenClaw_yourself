# LLM API 配置 (支持 OpenAI / DeepSeek / Ollama 等 OpenAI 兼容接口)
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 服务配置
HOST=127.0.0.1
WS_PORT=8765

# 数据库
DB_PATH=data/cybereternity.db

# 角色自主行为间隔（秒）
AUTO_BEHAVIOR_INTERVAL=15

# 对话记忆上限
MAX_CORE_MEMORIES_PER_QUERY=5
MAX_CONVERSATION_HISTORY=10

# 记忆系统 v2（Markdown + FTS5）
MEMORY_AUTO_LEARN=true
MEMORY_DAILY_INJECT_DAYS=2
MEMORY_FTS_MIN_SCORE=0.05

# 角色间互动
CHARACTER_INTERACTION_INTERVAL=60
CHARACTER_INTERACTION_PROBABILITY=0.5

# 定期反思（Stanford Generative Agents 风格）
REFLECTION_CHECK_INTERVAL=300
REFLECTION_ACTIVITY_THRESHOLD_MINUTES=120
REFLECTION_DAILY_HOUR=22

# 全局用户档案
USER_PROFILE_ENABLED=true
